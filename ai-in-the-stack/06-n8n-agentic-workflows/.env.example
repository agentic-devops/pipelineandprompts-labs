# Copy to .env and fill in before `docker compose up`

# Timezone for n8n's scheduler/logs
GENERIC_TIMEZONE=UTC

# Slack channel ID the workflow posts incident notifications to
# (required — the workflow will fail on the Slack node without it)
SLACK_CHANNEL_ID=

# Slack channel ID the error workflow posts failures to
SLACK_ERROR_CHANNEL_ID=

# --- Real-path only (not needed for the demo quickstart) ---

# Real MCP server address, once you swap out demo-mcp-server
# MCP_SERVER_SSE_URL=http://platform-mcp-server:8080/sse

# Real RAG service address, once you swap out demo-rag-service
# RAG_SERVICE_URL=http://runbook-rag-service:8080/query

# GCP project for Vertex AI, if using the real LLM path
# GCP_PROJECT_ID=
# GCP_REGION=us-central1
