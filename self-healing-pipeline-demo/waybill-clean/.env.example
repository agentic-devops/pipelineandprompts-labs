# ── Database ──────────────────────────────────────────────────────────────────
# Host port is 5433 to avoid conflict with a local Postgres on 5432
DATABASE_URL=postgresql://waybill:changeme@localhost:5433/waybill
POSTGRES_PASSWORD=changeme

# ── App ───────────────────────────────────────────────────────────────────────
SLOT=blue
APP_VERSION=dev

# ── Image ─────────────────────────────────────────────────────────────────────
IMAGE_NAME=waybill
BLUE_TAG=local
GREEN_TAG=local

# ── GitHub Actions Secrets (set in Settings → Secrets → Actions, not here) ───
# SERVER_IP             — deploy server IP
# SSH_PRIVATE_KEY       — ed25519 deploy key (no passphrase)
# POSTGRES_PASSWORD     — strong random password in production
# SLACK_WEBHOOK_URL     — https://hooks.slack.com/services/...
# PAGERDUTY_ROUTING_KEY — Events API v2 key, scoped to this pipeline only
